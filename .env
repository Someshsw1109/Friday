# Porcupine Hotword Detection (Get your key from https://console.picovoice.ai/)
PORCUPINE_ACCESS_KEY=YOUR_PICOVOICE_ACCESS_KEY

# Weather API (Get your key from https://openweathermap.org/api)
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# News API (Get your key from https://newsapi.org/)
NEWS_API_KEY=YOUR_NEWS_API_KEY

# Wolfram Alpha (Get your app ID from https://developer.wolframalpha.com/)
WOLFRAMALPHA_APP_ID=YOUR_WOLFRAMALPHA_APP_ID

# Email Configuration (For Gmail, use App Passwords)
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Optional: Geocoding API Key
GEOCODING_API_KEY=YOUR_GEOCODING_API_KEY
